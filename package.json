{
  "name": "@22-2/esbuild-plugin-obsidian-copy",
  "version": "0.1.0",
  "description": "esbuild plugin to copy Obsidian plugin files to a target plugins directory",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "esbuild",
    "plugin",
    "obsidian",
    "copy"
  ],
  "author": "22-2",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
