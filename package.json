{
  "name": "@22-2/obsidian-copy-bundler-plugin",
  "version": "1.0.2",
  "description": "bundler plugin to copy Obsidian plugin files to a target plugins directory",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "esbuild",
    "plugin",
    "obsidian",
    "copy"
  ],
  "author": "22-2",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "esbuild": ">=0.27.0",
    "vite": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
